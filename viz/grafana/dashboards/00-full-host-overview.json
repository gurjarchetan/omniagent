{
  "uid": "omniagent-full-host",
  "title": "OmniAgent — Full Host Overview",
  "description": "Complete single-pane-of-glass view: CPU, memory, swap, load, uptime, disk, network, containers, processes, and paging",
  "tags": ["omniagent", "overview"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(omniagent_system_uptime, host)",
        "query": { "query": "label_values(omniagent_system_uptime, host)", "refId": "A" },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "System Health",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_cpu_usage{host=\"$host\",mode=\"total\"}", "legendFormat": "CPU", "refId": "A" }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 88 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_memory_utilization{host=\"$host\"}", "legendFormat": "RAM", "refId": "A" }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Root Disk Usage",
      "gridPos": { "x": 6, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_filesystem_utilization{host=\"$host\",mountpoint=\"/\"}", "legendFormat": "/ disk", "refId": "A" }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Load Avg (1m)",
      "gridPos": { "x": 9, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_load_1{host=\"$host\"}", "legendFormat": "load 1m", "refId": "A" }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_uptime{host=\"$host\"}", "legendFormat": "uptime", "refId": "A" }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Total RAM",
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_memory_total{host=\"$host\"}", "legendFormat": "total RAM", "refId": "A" }
      ]
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Processes",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_procs_total{host=\"$host\"}", "legendFormat": "total", "refId": "A" }
      ]
    },

    {
      "id": 9,
      "type": "stat",
      "title": "CPU Cores",
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_cpu_count{host=\"$host\"}", "legendFormat": "cores", "refId": "A" }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Usage by Mode",
      "gridPos": { "x": 0, "y": 6, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 20, "lineWidth": 2, "drawStyle": "line", "stacking": { "mode": "none" } }
        }
      },
      "targets": [
        { "expr": "omniagent_system_cpu_usage{host=\"$host\",mode=\"total\"}", "legendFormat": "total", "refId": "A" },
        { "expr": "omniagent_system_cpu_user{host=\"$host\"}", "legendFormat": "user", "refId": "B" },
        { "expr": "omniagent_system_cpu_system{host=\"$host\"}", "legendFormat": "system", "refId": "C" },
        { "expr": "omniagent_system_cpu_iowait{host=\"$host\"}", "legendFormat": "iowait", "refId": "D" },
        { "expr": "omniagent_system_cpu_steal{host=\"$host\"}", "legendFormat": "steal", "refId": "E" },
        { "expr": "omniagent_system_cpu_irq{host=\"$host\"}", "legendFormat": "irq", "refId": "F" }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Load Average",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        { "expr": "omniagent_system_load_1{host=\"$host\"}", "legendFormat": "load 1m", "refId": "A" },
        { "expr": "omniagent_system_load_5{host=\"$host\"}", "legendFormat": "load 5m", "refId": "B" },
        { "expr": "omniagent_system_load_15{host=\"$host\"}", "legendFormat": "load 15m", "refId": "C" }
      ]
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Per-CPU Usage (all cores)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 5, "lineWidth": 1 }
        }
      },
      "targets": [
        { "expr": "omniagent_system_cpu_usage_percpu{host=\"$host\",mode=\"total\"}", "legendFormat": "{{cpu}}", "refId": "A" }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Memory Breakdown",
      "gridPos": { "x": 0, "y": 23, "w": 16, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        { "expr": "omniagent_system_memory_total{host=\"$host\"}", "legendFormat": "total", "refId": "A" },
        { "expr": "omniagent_system_memory_usage{host=\"$host\"}", "legendFormat": "used", "refId": "B" },
        { "expr": "omniagent_system_memory_available{host=\"$host\"}", "legendFormat": "available", "refId": "C" },
        { "expr": "omniagent_system_memory_cached{host=\"$host\"}", "legendFormat": "cached", "refId": "D" },
        { "expr": "omniagent_system_memory_buffers{host=\"$host\"}", "legendFormat": "buffers", "refId": "E" },
        { "expr": "omniagent_system_memory_slab{host=\"$host\"}", "legendFormat": "slab", "refId": "F" }
      ]
    },

    {
      "id": 22,
      "type": "gauge",
      "title": "Memory Utilization",
      "gridPos": { "x": 16, "y": 23, "w": 4, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 88 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_memory_utilization{host=\"$host\"}", "legendFormat": "", "refId": "A" }
      ]
    },

    {
      "id": 23,
      "type": "timeseries",
      "title": "Swap Usage",
      "gridPos": { "x": 20, "y": 23, "w": 4, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 30, "lineWidth": 2 }
        }
      },
      "targets": [
        { "expr": "omniagent_system_swap_usage{host=\"$host\"}", "legendFormat": "used", "refId": "A" },
        { "expr": "omniagent_system_swap_total{host=\"$host\"}", "legendFormat": "total", "refId": "B" }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "Disk & Filesystem",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "type": "bargauge",
      "title": "Filesystem Usage % (all mounts)",
      "gridPos": { "x": 0, "y": 33, "w": 8, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "omniagent_system_filesystem_utilization{host=\"$host\",device!~\"overlay|none|tmpfs|shm\"}",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Disk I/O Rate (all devices)",
      "gridPos": { "x": 8, "y": 33, "w": 16, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*write.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        { "expr": "omniagent_system_disk_io_rate{host=\"$host\",direction=\"read\"}", "legendFormat": "{{device}} read", "refId": "A" },
        { "expr": "omniagent_system_disk_io_rate{host=\"$host\",direction=\"write\"}", "legendFormat": "{{device}} write", "refId": "B" }
      ]
    },

    {
      "id": 40,
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 }
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "Network I/O Rate (all interfaces)",
      "gridPos": { "x": 0, "y": 44, "w": 16, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*transmit.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        {
          "expr": "omniagent_system_network_io_rate{host=\"$host\",device!~\"lo|veth.*|br-.*|docker.*\",direction=\"receive\"}",
          "legendFormat": "{{device}} rx",
          "refId": "A"
        },
        {
          "expr": "omniagent_system_network_io_rate{host=\"$host\",device!~\"lo|veth.*|br-.*|docker.*\",direction=\"transmit\"}",
          "legendFormat": "{{device}} tx",
          "refId": "B"
        }
      ]
    },

    {
      "id": 42,
      "type": "stat",
      "title": "TCP Connections",
      "gridPos": { "x": 16, "y": 44, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "targets": [
        { "expr": "omniagent_system_network_connections{host=\"$host\",protocol=\"tcp\"}", "legendFormat": "TCP", "refId": "A" }
      ]
    },

    {
      "id": 43,
      "type": "stat",
      "title": "TCP TIME_WAIT",
      "gridPos": { "x": 20, "y": 44, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "omniagent_system_network_tcp_tw{host=\"$host\"}", "legendFormat": "TW", "refId": "A" }
      ]
    },

    {
      "id": 44,
      "type": "timeseries",
      "title": "Network Errors & Drops",
      "gridPos": { "x": 16, "y": 48, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "omniagent_system_network_errors{host=\"$host\",device!~\"lo|veth.*|br-.*|docker.*\"}",
          "legendFormat": "{{device}} errors",
          "refId": "A"
        },
        {
          "expr": "omniagent_system_network_dropped{host=\"$host\",device!~\"lo|veth.*|br-.*|docker.*\"}",
          "legendFormat": "{{device}} drops",
          "refId": "B"
        }
      ]
    },

    {
      "id": 50,
      "type": "row",
      "title": "Containers",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 53, "w": 24, "h": 1 }
    },

    {
      "id": 51,
      "type": "bargauge",
      "title": "Container CPU %",
      "gridPos": { "x": 0, "y": 54, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "omniagent_container_cpu_utilization{host=\"$host\"}",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 52,
      "type": "bargauge",
      "title": "Container Memory Usage",
      "gridPos": { "x": 8, "y": 54, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        {
          "expr": "omniagent_container_memory_usage{host=\"$host\"}",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 53,
      "type": "timeseries",
      "title": "Container CPU Over Time",
      "gridPos": { "x": 16, "y": 54, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
