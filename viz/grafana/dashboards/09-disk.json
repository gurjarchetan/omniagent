{
  "uid": "omniagent-disk",
  "title": "OmniAgent — Disk",
  "tags": ["omniagent"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "host", "label": "Host", "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(omniagent_system_disk_io_rate, host)",
        "query": {"query": "label_values(omniagent_system_disk_io_rate, host)", "refId": "A"},
        "refresh": 2, "multi": false, "includeAll": false, "sort": 1
      },
      {
        "name": "device", "label": "Disk", "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(omniagent_system_disk_io_rate{host=\"$host\"}, device)",
        "query": {"query": "label_values(omniagent_system_disk_io_rate{host=\"$host\"}, device)", "refId": "A"},
        "refresh": 2, "multi": true, "includeAll": true, "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Disk I/O Rate ($device)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "omniagent_system_disk_io_rate{host=\"$host\",device=~\"$device\",direction=\"read\"}", "legendFormat": "Read {{device}}", "refId": "A"},
        {"expr": "-omniagent_system_disk_io_rate{host=\"$host\",device=~\"$device\",direction=\"write\"}", "legendFormat": "Write {{device}}", "refId": "B"}
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Disk IOPS ($device)",
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "iops"}},
      "targets": [
        {"expr": "rate(omniagent_system_disk_operations{host=\"$host\",device=~\"$device\",direction=\"read\"}[5m])", "legendFormat": "Read IOPS {{device}}", "refId": "A"},
        {"expr": "-rate(omniagent_system_disk_operations{host=\"$host\",device=~\"$device\",direction=\"write\"}[5m])", "legendFormat": "Write IOPS {{device}}", "refId": "B"}
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Disk I/O In Progress ($device)",
      "gridPos": {"x": 12, "y": 9, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [
        {"expr": "omniagent_system_disk_io_in_progress{host=\"$host\",device=~\"$device\"}", "legendFormat": "{{device}}", "refId": "A"}
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Disk I/O Time (util) ($device)",
      "gridPos": {"x": 0, "y": 17, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"expr": "rate(omniagent_system_disk_io_time{host=\"$host\",device=~\"$device\"}[5m])", "legendFormat": "{{device}} io_time", "refId": "A"}
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Disk Operation Latency ($device)",
      "gridPos": {"x": 12, "y": 17, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"expr": "rate(omniagent_system_disk_operation_time{host=\"$host\",device=~\"$device\",direction=\"read\"}[5m]) / rate(omniagent_system_disk_operations{host=\"$host\",device=~\"$device\",direction=\"read\"}[5m])", "legendFormat": "Read latency {{device}}", "refId": "A"},
        {"expr": "rate(omniagent_system_disk_operation_time{host=\"$host\",device=~\"$device\",direction=\"write\"}[5m]) / rate(omniagent_system_disk_operations{host=\"$host\",device=~\"$device\",direction=\"write\"}[5m])", "legendFormat": "Write latency {{device}}", "refId": "B"}
      ]
    }
  ]
}
