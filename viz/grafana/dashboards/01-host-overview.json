{
  "uid": "omniagent-host",
  "title": "OmniAgent — Host Overview",
  "tags": ["omniagent"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "host", "label": "Host", "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(omniagent_system_cpu_usage, host)",
        "query": {"query": "label_values(omniagent_system_cpu_usage, host)", "refId": "A"},
        "refresh": 2, "multi": false, "includeAll": false, "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "row", "title": "CPU",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 2, "type": "timeseries", "title": "CPU Usage by Mode",
      "gridPos": {"x": 0, "y": 1, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0}},
      "targets": [
        {"expr": "omniagent_system_cpu_usage{host=\"$host\",mode=\"total\"}", "legendFormat": "Total", "refId": "A"},
        {"expr": "omniagent_system_cpu_user{host=\"$host\",mode=\"user\"}", "legendFormat": "User", "refId": "B"},
        {"expr": "omniagent_system_cpu_system{host=\"$host\",mode=\"system\"}", "legendFormat": "System", "refId": "C"},
        {"expr": "omniagent_system_cpu_iowait{host=\"$host\",mode=\"iowait\"}", "legendFormat": "IOWait", "refId": "D"},
        {"expr": "omniagent_system_cpu_steal{host=\"$host\",mode=\"steal\"}", "legendFormat": "Steal", "refId": "E"}
      ]
    },
    {
      "id": 3, "type": "row", "title": "Memory",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 4, "type": "timeseries", "title": "Memory Breakdown",
      "gridPos": {"x": 0, "y": 10, "w": 14, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"tooltip": {"mode": "multi"}, "stacking": {"mode": "normal"}},
      "targets": [
        {"expr": "omniagent_system_memory_usage{host=\"$host\"}", "legendFormat": "Used", "refId": "A"},
        {"expr": "omniagent_system_memory_buffers{host=\"$host\"}", "legendFormat": "Buffers", "refId": "B"},
        {"expr": "omniagent_system_memory_cached{host=\"$host\"}", "legendFormat": "Cached", "refId": "C"},
        {"expr": "omniagent_system_memory_slab{host=\"$host\"}", "legendFormat": "Slab", "refId": "D"},
        {"expr": "omniagent_system_memory_free{host=\"$host\"}", "legendFormat": "Free", "refId": "E"}
      ]
    },
    {
      "id": 5, "type": "gauge", "title": "Memory Utilization %",
      "gridPos": {"x": 14, "y": 10, "w": 5, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "omniagent_system_memory_utilization{host=\"$host\"}", "legendFormat": "", "refId": "A"}]
    },
    {
      "id": 6, "type": "gauge", "title": "Swap Utilization %",
      "gridPos": {"x": 19, "y": 10, "w": 5, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 40}, {"color": "red", "value": 80}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "omniagent_system_swap_utilization{host=\"$host\"}", "legendFormat": "", "refId": "A"}]
    },
    {
      "id": 7, "type": "row", "title": "Network",
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 8, "type": "timeseries", "title": "Network I/O Rate",
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "omniagent_system_network_io_rate{host=\"$host\",direction=\"receive\"}", "legendFormat": "RX {{device}}", "refId": "A"},
        {"expr": "-omniagent_system_network_io_rate{host=\"$host\",direction=\"transmit\"}", "legendFormat": "TX {{device}}", "refId": "B"}
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Network Errors & Drops",
      "gridPos": {"x": 12, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "pps"}},
      "targets": [
        {"expr": "rate(omniagent_system_network_errors{host=\"$host\"}[5m])", "legendFormat": "Errors {{device}} {{direction}}", "refId": "A"},
        {"expr": "rate(omniagent_system_network_dropped{host=\"$host\"}[5m])", "legendFormat": "Drops {{device}} {{direction}}", "refId": "B"}
      ]
    },
    {
      "id": 10, "type": "row", "title": "Disk",
      "gridPos": {"x": 0, "y": 27, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 11, "type": "timeseries", "title": "Disk I/O Rate",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "omniagent_system_disk_io_rate{host=\"$host\",direction=\"read\"}", "legendFormat": "Read {{device}}", "refId": "A"},
        {"expr": "-omniagent_system_disk_io_rate{host=\"$host\",direction=\"write\"}", "legendFormat": "Write {{device}}", "refId": "B"}
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Disk Operations/s",
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "rate(omniagent_system_disk_operations{host=\"$host\",direction=\"read\"}[5m])", "legendFormat": "Read {{device}}", "refId": "A"},
        {"expr": "rate(omniagent_system_disk_operations{host=\"$host\",direction=\"write\"}[5m])", "legendFormat": "Write {{device}}", "refId": "B"}
      ]
    },
    {
      "id": 13, "type": "row", "title": "Filesystem",
      "gridPos": {"x": 0, "y": 36, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 14, "type": "bargauge", "title": "Filesystem Usage %",
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal"},
      "targets": [{"expr": "omniagent_system_filesystem_utilization{host=\"$host\"}", "legendFormat": "{{mountpoint}}", "refId": "A"}]
    }
  ]
}
