{
  "uid": "omniagent-errors",
  "title": "OmniAgent — Errors & Alerts",
  "tags": ["omniagent"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "host", "label": "Host", "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(omniagent_system_cpu_usage, host)",
        "query": {"query": "label_values(omniagent_system_cpu_usage, host)", "refId": "A"},
        "refresh": 2, "multi": false, "includeAll": true, "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Network Errors (total)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(omniagent_system_network_errors{host=~\"$host\"})", "legendFormat": "Errors", "refId": "A"}]
    },
    {
      "id": 2, "type": "stat", "title": "Disk IOWait %",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 20}, {"color": "red", "value": 50}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "omniagent_system_cpu_iowait{host=~\"$host\",mode=\"iowait\"}", "legendFormat": "IOWait", "refId": "A"}]
    },
    {
      "id": 3, "type": "stat", "title": "Page Major Faults/s",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 100}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(omniagent_system_paging_major_faults{host=~\"$host\"}[5m])", "legendFormat": "Major Faults/s", "refId": "A"}]
    },
    {
      "id": 4, "type": "stat", "title": "Container OOM Events",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(omniagent_container_oom_events{host=~\"$host\"})", "legendFormat": "", "refId": "A"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Network Errors/Drops Rate",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "pps"}},
      "targets": [
        {"expr": "rate(omniagent_system_network_errors{host=~\"$host\"}[5m])", "legendFormat": "Errors {{device}} {{direction}}", "refId": "A"},
        {"expr": "rate(omniagent_system_network_dropped{host=~\"$host\"}[5m])", "legendFormat": "Drops {{device}} {{direction}}", "refId": "B"}
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "TCP States",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [
        {"expr": "omniagent_system_network_connections{host=~\"$host\",protocol=\"tcp\"}", "legendFormat": "TCP Established", "refId": "A"},
        {"expr": "omniagent_system_network_tcp_tw{host=~\"$host\"}", "legendFormat": "TIME_WAIT", "refId": "B"},
        {"expr": "omniagent_system_network_tcp_orphan{host=~\"$host\"}", "legendFormat": "Orphaned", "refId": "C"}
      ]
    },
    {
      "id": 7, "type": "logs", "title": "Error Logs",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "options": {"showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"},
      "targets": [
        {"expr": "{host=~\"$host\"} |= \"error\" or {host=~\"$host\"} |= \"ERROR\"", "refId": "A"}
      ]
    }
  ]
}
