{
  "title": "OmniAgent — Host Overview",
  "uid": "omniagent-host",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "omniagent_system_cpu_usage",
          "legendFormat": "{{mode}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "omniagent_system_memory_usage",
          "legendFormat": "used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "omniagent_system_memory_free",
          "legendFormat": "free",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 3,
      "title": "Memory Utilization %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "omniagent_system_memory_utilization * 100",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Swap Usage",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "omniagent_system_swap_usage",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 5,
      "title": "Container CPU Utilization %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "omniagent_container_cpu_utilization",
          "legendFormat": "{{container_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 }
      }
    },
    {
      "id": 6,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "omniagent_container_memory_usage",
          "legendFormat": "{{container_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 7,
      "title": "Top Processes — CPU Time",
      "type": "table",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, omniagent_process_cpu_time)",
          "instant": true,
          "legendFormat": "{{process}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 8,
      "title": "System Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "{job=\"omniagent\"}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
